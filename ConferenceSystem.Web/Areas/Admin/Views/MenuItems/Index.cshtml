@model IEnumerable<ConferenceSystem.Web.Entities.MenuItem>

@{
    ViewData["Title"] = "Menüler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Menüler</h1>
    <a href="/Admin/MenuItems/Create" class="btn btn-primary">Yeni Menü</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Başlık</th>
            <th>URL</th>
            <th>Sıra</th>
            <th>Aktif</th>
            <th>Yeni Sekme</th>
            <th style="width:180px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Url</td>
                <td>@item.SortOrder</td>
                <td>@(item.IsActive ? "Evet" : "Hayır")</td>
                <td>@(item.OpenInNewTab ? "Evet" : "Hayır")</td>
                <td>
                    <a href="/Admin/MenuItems/Edit/@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a href="/Admin/MenuItems/Delete/@item.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>