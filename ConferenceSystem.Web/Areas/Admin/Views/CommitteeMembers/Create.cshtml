@model ConferenceSystem.Web.Entities.CommitteeMember

@{
    ViewData["Title"] = "Yeni Kurul Üyesi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Yeni Kurul Üyesi</h1>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="ConferenceId" class="form-label">Konferans</label>
        <select asp-for="ConferenceId" asp-items="ViewBag.Conferences" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="CommitteeType" class="form-label">Kurul Türü</label>
        <select asp-for="CommitteeType" asp-items="ViewBag.CommitteeTypes" class="form-select"></select>
        <span asp-validation-for="CommitteeType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FullName" class="form-label">Ad Soyad</label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Ünvan</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Institution" class="form-label">Kurum</label>
        <input asp-for="Institution" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="SortOrder" class="form-label">Sıra</label>
        <input asp-for="SortOrder" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Aktif mi?</label>
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
    <a href="/Admin/CommitteeMembers" class="btn btn-secondary">Geri</a>
</form>