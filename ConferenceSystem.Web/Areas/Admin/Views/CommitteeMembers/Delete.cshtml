@model ConferenceSystem.Web.Entities.CommitteeMember

@{
    ViewData["Title"] = "Kurul Üyesi Sil";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Kurul Üyesi Sil</h1>

<div class="alert alert-warning">
    <strong>@Model.FullName</strong> kaydını silmek istediğine emin misin?
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Sil</button>
    <a href="/Admin/CommitteeMembers" class="btn btn-secondary">Vazgeç</a>
</form>