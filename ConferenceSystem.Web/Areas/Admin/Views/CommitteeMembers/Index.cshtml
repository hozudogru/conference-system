@model IEnumerable<ConferenceSystem.Web.Entities.CommitteeMember>

@{
    ViewData["Title"] = "Kurul Üyeleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Kurul Üyeleri</h1>
    <a href="/Admin/CommitteeMembers/Create" class="btn btn-primary">Yeni Kayıt</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Konferans</th>
            <th>Kurul</th>
            <th>Ad Soyad</th>
            <th>Ünvan</th>
            <th>Kurum</th>
            <th>Sıra</th>
            <th>Aktif</th>
            <th style="width:180px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Conference?.Name</td>
                <td>@item.CommitteeType</td>
                <td>@item.FullName</td>
                <td>@item.Title</td>
                <td>@item.Institution</td>
                <td>@item.SortOrder</td>
                <td>@(item.IsActive ? "Evet" : "Hayır")</td>
                <td>
                    <a href="/Admin/CommitteeMembers/Edit/@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a href="/Admin/CommitteeMembers/Delete/@item.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>