@model ConferenceSystem.Web.Entities.Session

@{
    ViewData["Title"] = "Oturum Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4">Oturum Düzenle</h1>

<form asp-action="EditSession" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ConferenceId" />

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Oturum Başlığı</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Room" class="form-label">Salon</label>
        <input asp-for="Room" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ChairName" class="form-label">Oturum Başkanı</label>
        <input asp-for="ChairName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="StartTime" class="form-label">Başlangıç</label>
        <input asp-for="StartTime" class="form-control" type="datetime-local"
               value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
    </div>

    <div class="mb-3">
        <label asp-for="EndTime" class="form-label">Bitiş</label>
        <input asp-for="EndTime" class="form-control" type="datetime-local"
               value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
    <a href="/Admin/Schedule?conferenceId=@Model.ConferenceId" class="btn btn-secondary">Geri</a>
</form>