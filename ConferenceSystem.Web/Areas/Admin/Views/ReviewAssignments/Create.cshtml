@model ConferenceSystem.Web.Entities.ReviewAssignment

@{
    ViewData["Title"] = "Hakem Ata";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Hakem Ata</h1>

<div class="mb-3">
    <strong>Bildiri:</strong> @ViewBag.SubmissionTitle
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SubmissionId" />

    <div class="mb-3">
        <label asp-for="ReviewerId" class="form-label">Hakem</label>
        <select asp-for="ReviewerId" asp-items="ViewBag.Reviewers" class="form-select">
            <option value="">Hakem seçiniz</option>
        </select>
        <span asp-validation-for="ReviewerId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label">Durum</label>
        <input asp-for="Status" class="form-control" readonly />
    </div>

    <button type="submit" class="btn btn-success">Ata</button>
    <a href="/Admin/Submissions/Detail/@ViewBag.SubmissionId" class="btn btn-secondary">Geri</a>
</form>