@model IEnumerable<ConferenceSystem.Web.Entities.RegistrationCategory>
@{
    ViewData["Title"] = "RegistrationCategories";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var conferences = ViewBag.Conferences as IEnumerable<ConferenceSystem.Web.Entities.Conference>;
    long? selectedConferenceId = ViewBag.SelectedConferenceId as long?;
}
@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Kayıt Kategorileri</h1>
    <a class="btn btn-primary" href="/Admin/RegistrationCategories/Create@(selectedConferenceId != null ? $"?conferenceId={selectedConferenceId}" : "")">Yeni Ekle</a>
</div>
<form method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-4">
            <select name="conferenceId" class="form-select" onchange="this.form.submit()">
                <option value="">Tüm konferanslar</option>
                @if (conferences != null)
                {
                    foreach (var c in conferences)
                    {
                        <option value="@c.Id" selected="@(selectedConferenceId == c.Id)">@c.Name</option>
                    }
                }
            </select>
        </div>
    </div>
</form>
<table class="table table-striped">
    <thead><tr><th>Kategori</th><th>Açıklama</th><th>Ücret</th><th>Sıra</th><th>Durum</th><th></th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.CategoryName</td><td>@item.Description</td><td>@item.Fee @item.Currency</td><td>@item.SortOrder</td><td>@(item.IsActive ? "Aktif" : "Pasif")</td><td class="text-end"><a class="btn btn-sm btn-outline-primary" href="/Admin/RegistrationCategories/Edit/@item.Id">Düzenle</a> <a class="btn btn-sm btn-outline-danger" href="/Admin/RegistrationCategories/Delete/@item.Id">Sil</a></td></tr> }</tbody></table>