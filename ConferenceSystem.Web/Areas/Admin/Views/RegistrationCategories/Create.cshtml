@model ConferenceSystem.Web.Entities.RegistrationCategory
@{
    ViewData["Title"] = "Kayıt Kategorisi Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var conferences = ViewBag.Conferences as IEnumerable<ConferenceSystem.Web.Entities.Conference>;
}
<h1 class="mb-4">@ViewData["Title"]</h1>
<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="mb-3">
        <label asp-for="ConferenceId" class="form-label">Konferans</label>
        <select asp-for="ConferenceId" class="form-select">
            @if (conferences != null)
            {
                foreach (var c in conferences)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            }
        </select>
    </div>
<div class="mb-3"><label asp-for="CategoryName" class="form-label">Kategori</label><input asp-for="CategoryName" class="form-control" /></div>
<div class="mb-3"><label asp-for="Description" class="form-label">Açıklama</label><input asp-for="Description" class="form-control" /></div>
<div class="row g-3"><div class="col-md-4"><label asp-for="Fee" class="form-label">Ücret</label><input asp-for="Fee" class="form-control" /></div><div class="col-md-4"><label asp-for="Currency" class="form-label">Para Birimi</label><input asp-for="Currency" class="form-control" /></div><div class="col-md-4"><label asp-for="SortOrder" class="form-label">Sıra</label><input asp-for="SortOrder" class="form-control" /></div></div>
<div class="form-check mb-4"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Aktif</label></div>
<button type="submit" class="btn btn-primary">Kaydet</button>
<a class="btn btn-outline-secondary" href="javascript:history.back()">Vazgeç</a>
</form>