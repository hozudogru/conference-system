@model IEnumerable<ConferenceSystem.Web.Entities.ContentPage>

@{
    ViewData["Title"] = "Sayfalar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Sayfalar</h1>
    <a href="/Admin/Pages/Create" class="btn btn-primary">Yeni Sayfa</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Başlık</th>
            <th>Slug</th>
            <th>Yayın</th>
            <th>Sıra</th>
            <th style="width:180px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.Slug</td>
                <td>@(item.IsPublished ? "Evet" : "Hayır")</td>
                <td>@item.SortOrder</td>
                <td>
                    <a href="/Admin/Pages/Edit/@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a href="/Admin/Pages/Delete/@item.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>