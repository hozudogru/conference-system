@model IEnumerable<ConferenceSystem.Web.Entities.Review>

@{
    ViewData["Title"] = "Değerlendirmeler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4">Değerlendirmeler</h1>
<div class="mb-3">
    <a href="/Admin/Reviews/ExportExcel" class="btn btn-success">Excel'e Aktar</a>
</div>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Bildiri</th>
            <th>Hakem</th>
            <th>Öneri</th>
            <th>Tarih</th>
            <th style="width:120px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ReviewAssignment?.Submission?.Title</td>
                <td>@item.ReviewAssignment?.Reviewer?.FullName</td>
                <td>@item.Recommendation</td>
                <td>@item.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <a href="/Admin/Reviews/Detail/@item.Id" class="btn btn-sm btn-primary">Detay</a>
                </td>
            </tr>
        }
    </tbody>
</table>