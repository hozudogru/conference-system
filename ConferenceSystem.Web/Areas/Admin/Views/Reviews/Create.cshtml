@model ConferenceSystem.Web.Entities.Review

@{
    ViewData["Title"] = "Değerlendirme Gir";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Değerlendirme Gir</h1>

<div class="mb-3">
    <strong>Atama:</strong> @ViewBag.AssignmentInfo
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ReviewAssignmentId" />

    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="OriginalityScore" class="form-label">Özgünlük</label>
            <input asp-for="OriginalityScore" type="number" min="1" max="5" class="form-control" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="MethodScore" class="form-label">Yöntem</label>
            <input asp-for="MethodScore" type="number" min="1" max="5" class="form-control" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="RelevanceScore" class="form-label">Uygunluk</label>
            <input asp-for="RelevanceScore" type="number" min="1" max="5" class="form-control" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="WritingScore" class="form-label">Yazım</label>
            <input asp-for="WritingScore" type="number" min="1" max="5" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="CommentToAuthor" class="form-label">Yazara Yorum</label>
        <textarea asp-for="CommentToAuthor" class="form-control" rows="5"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="CommentToEditor" class="form-label">Editöre Not</label>
        <textarea asp-for="CommentToEditor" class="form-control" rows="4"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Recommendation" class="form-label">Öneri</label>
        <select asp-for="Recommendation" asp-items="ViewBag.Recommendations" class="form-select"></select>
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
    <a href="/Admin/ReviewAssignments" class="btn btn-secondary">Geri</a>
</form>