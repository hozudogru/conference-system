@model ConferenceSystem.Web.Entities.ImportantDate

@{
    ViewData["Title"] = "Önemli Tarih Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Önemli Tarih Düzenle</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="ConferenceId" class="form-label">Konferans</label>
        <select asp-for="ConferenceId" asp-items="ViewBag.Conferences" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Başlık</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DateValue" class="form-label">Tarih</label>
        <input asp-for="DateValue" type="date" class="form-control"
               value="@Model.DateValue.ToString("yyyy-MM-dd")" />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Açıklama</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="SortOrder" class="form-label">Sıra</label>
        <input asp-for="SortOrder" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Aktif mi?</label>
    </div>

    <button type="submit" class="btn btn-success">Güncelle</button>
    <a href="/Admin/ImportantDates" class="btn btn-secondary">Geri</a>
</form>