@using ConferenceSystem.Web.Data
@inject AppDbContext DbContext

@{
    var path = Context.Request.Path.ToString().ToLower();
    var editorDisplayName = Context.Session.GetString("EditorDisplayName") ?? "Editor";
    var editorEmail = Context.Session.GetString("EditorEmail") ?? "";

    string IsActive(params string[] urls)
    {
        foreach (var url in urls)
        {
            if (!string.IsNullOrWhiteSpace(url) && path.StartsWith(url.ToLower()))
                return "active";
        }
        return "";
    }

    string IsOpen(params string[] urls)
    {
        foreach (var url in urls)
        {
            if (!string.IsNullOrWhiteSpace(url) && path.StartsWith(url.ToLower()))
                return "show";
        }
        return "";
    }

    var queryId = Context.Request.Query["conferenceId"].FirstOrDefault();

    long? selectedConferenceId = null;
    if (!string.IsNullOrWhiteSpace(queryId) && long.TryParse(queryId, out var parsedId))
    {
        selectedConferenceId = parsedId;
    }

    var currentConference = selectedConferenceId != null
        ? DbContext.Conferences.FirstOrDefault(x => x.Id == selectedConferenceId.Value)
        : DbContext.Conferences
            .OrderByDescending(x => x.IsActive)
            .ThenByDescending(x => x.StartDate)
            .FirstOrDefault();

    var conferences = DbContext.Conferences
        .OrderByDescending(x => x.StartDate)
        .ToList();

    var scheduleUrl = currentConference != null
        ? $"/Admin/Schedule?conferenceId={currentConference.Id}"
        : "/Admin/Conferences";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
            body {
                background: #f3f6fb;
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                color: #111827;
            }

            .admin-wrapper {
                display: flex;
                min-height: 100vh;
            }

            .admin-sidebar {
                width: 295px;
                background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
                color: #fff;
                padding: 1.2rem 1rem;
                flex-shrink: 0;
                box-shadow: 8px 0 24px rgba(15, 23, 42, 0.08);
                overflow-y: auto;
            }

            .admin-brand {
                display: flex;
                align-items: center;
                gap: 0.7rem;
                font-size: 1.45rem;
                font-weight: 700;
                margin-bottom: 1.4rem;
                color: #fff;
                text-decoration: none;
            }

                .admin-brand i {
                    font-size: 1.35rem;
                    color: #60a5fa;
                }

            .sidebar-section {
                margin-bottom: 0.45rem;
            }

            .sidebar-parent {
                display: flex;
                align-items: center;
                justify-content: space-between;
                color: #e5e7eb;
                text-decoration: none;
                padding: 0.82rem 0.95rem;
                border-radius: 14px;
                transition: all 0.2s ease;
                font-size: 0.96rem;
                cursor: pointer;
            }

                .sidebar-parent:hover {
                    background: rgba(255,255,255,0.08);
                    color: #fff;
                }

                .sidebar-parent.active {
                    background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
                    color: #fff;
                    font-weight: 600;
                    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
                }

            .sidebar-parent-left {
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

            .sidebar-parent i.icon {
                width: 18px;
                text-align: center;
                color: #93c5fd;
            }

            .sidebar-parent.active i.icon,
            .sidebar-parent.active i.chevron {
                color: #fff;
            }

            .sidebar-parent i.chevron {
                font-size: 0.85rem;
                color: #94a3b8;
            }

            .sidebar-children {
                padding-left: 1.1rem;
                margin-top: 0.35rem;
                margin-bottom: 0.55rem;
            }

            .sidebar-child {
                display: block;
                color: #cbd5e1;
                text-decoration: none;
                padding: 0.62rem 0.9rem;
                border-radius: 12px;
                margin-bottom: 0.25rem;
                font-size: 0.92rem;
                transition: all 0.2s ease;
            }

                .sidebar-child:hover {
                    background: rgba(255,255,255,0.06);
                    color: #fff;
                }

                .sidebar-child.active {
                    background: rgba(37, 99, 235, 0.22);
                    color: #fff;
                    font-weight: 600;
                }

            .admin-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .admin-topbar {
                background: rgba(255,255,255,0.92);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid #e5e7eb;
                padding: 1rem 1.5rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 10;
            }

            .admin-topbar-title {
                font-size: 1.15rem;
                font-weight: 700;
                color: #0f172a;
                margin: 0;
            }

            .admin-topbar-subtitle {
                font-size: 0.85rem;
                color: #6b7280;
                margin-top: 0.1rem;
            }

            .admin-content {
                padding: 1.5rem;
            }

            .admin-page-card {
                background: #fff;
                border-radius: 20px;
                box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
                padding: 1.4rem;
                border: 1px solid #eef2f7;
            }

            .sidebar-toggle {
                display: none;
            }

            select.form-select-sm {
                border-radius: 10px;
                border: 1px solid #e5e7eb;
                font-weight: 500;
                min-width: 220px;
            }

            @@media (max-width: 992px) {
                .admin-wrapper {
                    flex-direction: column;
                }

                .admin-sidebar {
                    width: 100%;
                    display: none;
                }

                    .admin-sidebar.show {
                        display: block;
                    }

                .sidebar-toggle {
                    display: inline-block;
                }

                .admin-content {
                    padding: 1rem;
                }
            }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <aside class="admin-sidebar" id="adminSidebar">
            <a href="/Admin/Home" class="admin-brand">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Admin Panel</span>
            </a>
            <div class="sidebar-section">
                <a class="sidebar-parent @IsActive("/admin/announcements")" data-bs-toggle="collapse" href="#menuAnnouncements">
                    <span class="sidebar-parent-left">
                        <i class="bi bi-megaphone icon"></i>
                        <span>Duyurular</span>
                    </span>
                    <i class="bi bi-chevron-down chevron"></i>
                </a>
                <div class="collapse @IsOpen("/admin/announcements")" id="menuAnnouncements">
                    <div class="sidebar-children">
                        <a class="sidebar-child @IsActive("/admin/announcements")" href="/Admin/Announcements">Duyuru Listesi</a>
                        <a class="sidebar-child @IsActive("/admin/announcements/create")" href="/Admin/Announcements/Create">Duyuru Ekle</a>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <a class="sidebar-parent @IsActive("/admin/pages", "/admin/menuitems")" data-bs-toggle="collapse" href="#menuPages">
                    <span class="sidebar-parent-left">
                        <i class="bi bi-file-earmark-text icon"></i>
                        <span>Sayfalar & Menüler</span>
                    </span>
                    <i class="bi bi-chevron-down chevron"></i>
                </a>
                <div class="collapse @IsOpen("/admin/pages", "/admin/menuitems")" id="menuPages">
                    <div class="sidebar-children">
                        <a class="sidebar-child @IsActive("/admin/pages")" href="/Admin/Pages">Sayfa Listesi</a>
                        <a class="sidebar-child @IsActive("/admin/pages/create")" href="/Admin/Pages/Create">Sayfa Ekle</a>
                        <a class="sidebar-child @IsActive("/admin/menuitems")" href="/Admin/MenuItems">Menü Listesi</a>
                        <a class="sidebar-child @IsActive("/admin/menuitems/create")" href="/Admin/MenuItems/Create">Menü Ekle</a>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <a class="sidebar-parent @IsActive("/admin/committeemembers", "/admin/importantdates", "/admin/submissions", "/admin/registrationcategories", "/admin/speakers", "/admin/homepagesettings", "/admin/themesettings")" data-bs-toggle="collapse" href="#menuContent">
                    <span class="sidebar-parent-left">
                        <i class="bi bi-folder2-open icon"></i>
                        <span>İçerik</span>
                    </span>
                    <i class="bi bi-chevron-down chevron"></i>
                </a>
                <div class="collapse @IsOpen("/admin/committeemembers", "/admin/importantdates", "/admin/submissions", "/admin/registrationcategories", "/admin/speakers", "/admin/homepagesettings", "/admin/themesettings")" id="menuContent">
                    <div class="sidebar-children">
                        <a class="sidebar-child @IsActive("/admin/homepagesettings")" href="/Admin/HomePageSettings/Edit">Ana Sayfa Ayarları</a>
                        <a class="sidebar-child @IsActive("/admin/themesettings")" href="/Admin/ThemeSettings">Tema Ayarları</a>
                        <a class="sidebar-child @IsActive("/admin/registrationcategories")" href="/Admin/RegistrationCategories">Kayıt Kategorileri</a>
                        <a class="sidebar-child @IsActive("/admin/speakers")" href="/Admin/Speakers">Konuşmacılar</a>
                        <a class="sidebar-child @IsActive("/admin/committeemembers")" href="/Admin/CommitteeMembers">Kurullar</a>
                        <a class="sidebar-child @IsActive("/admin/importantdates")" href="/Admin/ImportantDates">Önemli Tarihler</a>
                        <a class="sidebar-child @IsActive("/admin/submissions")" href="/Admin/Submissions">Bildiriler</a>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <a class="sidebar-parent @IsActive("/admin/reviewers", "/admin/reviewassignments", "/admin/reviews", "/admin/editorialdecisions")" data-bs-toggle="collapse" href="#menuReview">
                    <span class="sidebar-parent-left">
                        <i class="bi bi-clipboard-check icon"></i>
                        <span>Değerlendirme</span>
                    </span>
                    <i class="bi bi-chevron-down chevron"></i>
                </a>
                <div class="collapse @IsOpen("/admin/reviewers", "/admin/reviewassignments", "/admin/reviews", "/admin/editorialdecisions")" id="menuReview">
                    <div class="sidebar-children">
                        <a class="sidebar-child @IsActive("/admin/reviewers")" href="/Admin/Reviewers">Hakemler</a>
                        <a class="sidebar-child @IsActive("/admin/reviewassignments")" href="/Admin/ReviewAssignments">Hakem Atamaları</a>
                        <a class="sidebar-child @IsActive("/admin/reviews")" href="/Admin/Reviews">Değerlendirmeler</a>
                        <a class="sidebar-child @IsActive("/admin/editorialdecisions")" href="/Admin/EditorialDecisions">Nihai Kararlar</a>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <a class="sidebar-parent @IsActive("/admin/schedule", "/admin/auditlogs")" data-bs-toggle="collapse" href="#menuProgram">
                    <span class="sidebar-parent-left">
                        <i class="bi bi-easel icon"></i>
                        <span>Program & Rapor</span>
                    </span>
                    <i class="bi bi-chevron-down chevron"></i>
                </a>
                <div class="collapse @IsOpen("/admin/schedule", "/admin/auditlogs")" id="menuProgram">
                    <div class="sidebar-children">
                        <a class="sidebar-child @IsActive("/admin/schedule")" href="@scheduleUrl">Program Editörü</a>
                        <a class="sidebar-child @IsActive("/admin/auditlogs")" href="/Admin/AuditLogs">Audit Log</a>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <a class="sidebar-parent @IsActive("/admin/bulkannouncements")" data-bs-toggle="collapse" href="#menuCommunication">
                    <span class="sidebar-parent-left">
                        <i class="bi bi-envelope-paper icon"></i>
                        <span>İletişim</span>
                    </span>
                    <i class="bi bi-chevron-down chevron"></i>
                </a>
                    <div class="collapse @IsOpen("/admin/bulkannouncements", "/admin/systemsettings")" id="menuCommunication">
                        <div class="sidebar-children">
                            <a class="sidebar-child @IsActive("/admin/bulkannouncements")" href="/Admin/BulkAnnouncements">
                                Toplu Duyuru
                            </a>

                            <a class="sidebar-child @IsActive("/admin/systemsettings/smtp")" href="/Admin/SystemSettings/Smtp">
                                SMTP Ayarları
                            </a>
                        </div>
                    </div>
                </div>
        </aside>

        <main class="admin-main">
            <div class="admin-topbar">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-dark sidebar-toggle" type="button" onclick="toggleSidebar()">
                        <i class="bi bi-list"></i>
                    </button>
                    <div>
                        <h1 class="admin-topbar-title">@ViewData["Title"]</h1>
                        <div class="admin-topbar-subtitle">Conference Management Admin</div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                    <form method="get" id="conferenceSelectorForm">
                        <select class="form-select form-select-sm"
                                name="conferenceId"
                                onchange="document.getElementById('conferenceSelectorForm').submit()">
                            @foreach (var c in conferences)
                            {
                                <option value="@c.Id" selected="@(currentConference != null && currentConference.Id == c.Id)">
                                    @c.Name
                                </option>
                            }
                        </select>
                    </form>

                    <div class="text-end small text-muted me-2">
                        <div class="fw-semibold text-dark">@editorDisplayName</div>
                        @if (!string.IsNullOrWhiteSpace(editorEmail))
                        {
                            <div>@editorEmail</div>
                        }
                    </div>

                    <a href="/" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-house-door me-1"></i> Siteye Dön
                    </a>

                    <form asp-controller="AdminAuth" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i> Çıkış
                        </button>
                    </form>
                </div>
            </div>

            <div class="admin-content">
                <div class="admin-page-card">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
            function toggleSidebar() {
                const sidebar = document.getElementById('adminSidebar');
                sidebar.classList.toggle('show');
            }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>