@model ConferenceSystem.Web.Entities.Announcement

@{
    ViewData["Title"] = "Duyuru Sil";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Duyuru Sil</h1>

<div class="alert alert-warning">
    <strong>@Model.Title</strong> başlıklı duyuruyu silmek istediğine emin misin?
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Sil</button>
    <a href="/Admin/Announcements" class="btn btn-secondary">Vazgeç</a>
</form>