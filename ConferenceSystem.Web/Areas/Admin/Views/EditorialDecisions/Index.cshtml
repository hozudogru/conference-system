@model IEnumerable<ConferenceSystem.Web.Entities.EditorialDecision>

@{
    ViewData["Title"] = "Nihai Kararlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4">Nihai Kararlar</h1>
<div class="mb-3">
    <a href="/Admin/EditorialDecisions/ExportExcel" class="btn btn-success">Excel'e Aktar</a>
</div>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Bildiri</th>
            <th>Karar</th>
            <th>Tarih</th>
            <th style="width:120px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Submission?.Title</td>
                <td>@item.DecisionType</td>
                <td>@item.DecidedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <a href="/Admin/EditorialDecisions/Detail/@item.Id" class="btn btn-sm btn-primary">Detay</a>
                </td>
            </tr>
        }
    </tbody>
</table>