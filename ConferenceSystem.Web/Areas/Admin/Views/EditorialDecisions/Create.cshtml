@model ConferenceSystem.Web.Entities.EditorialDecision

@{
    ViewData["Title"] = "Nihai Karar Ver";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Nihai Karar Ver</h1>

<div class="mb-3">
    <strong>Bildiri:</strong> @ViewBag.SubmissionTitle
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SubmissionId" />

    <div class="mb-3">
        <label asp-for="DecisionType" class="form-label">Karar</label>
        <select asp-for="DecisionType" asp-items="ViewBag.DecisionTypes" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="DecisionNote" class="form-label">Karar Notu</label>
        <textarea asp-for="DecisionNote" class="form-control" rows="6"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
    <a href="/Admin/Submissions/Detail/@ViewBag.SubmissionId" class="btn btn-secondary">Geri</a>
</form>