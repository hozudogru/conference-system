@model IEnumerable<ConferenceSystem.Web.Entities.Conference>

@{
    ViewData["Title"] = "Konferanslar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Konferanslar</h1>
    <a href="/Admin/Conferences/Create" class="btn btn-primary">Yeni Konferans</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Kısa Ad</th>
            <th>Yer</th>
            <th>Tarih</th>
            <th>Aktif</th>
            <th style="width:180px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.ShortName</td>
                <td>@item.Location</td>
                <td>@item.StartDate.ToString("dd.MM.yyyy") - @item.EndDate.ToString("dd.MM.yyyy")</td>
                <td>@(item.IsActive ? "Evet" : "Hayır")</td>
                <td>
                    <a href="/Admin/Conferences/Edit/@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a href="/Admin/Conferences/Delete/@item.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>