@model ConferenceSystem.Web.Entities.Conference

@{
    ViewData["Title"] = "Konferans Sil";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Konferans Sil</h1>

<div class="alert alert-warning">
    <strong>@Model.Name</strong> konferansını silmek istediğine emin misin?
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Sil</button>
    <a href="/Admin/Conferences" class="btn btn-secondary">Vazgeç</a>
</form>