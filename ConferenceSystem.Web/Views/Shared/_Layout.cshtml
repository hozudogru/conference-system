@using ConferenceSystem.Web.Data
@inject AppDbContext DbContext

@{
    var path = Context.Request.Path.ToString().ToLowerInvariant();
    var portalRole = Context.Session.GetString("PortalRole");

    string ActiveClass(params string[] urls)
    {
        foreach (var rawUrl in urls)
        {
            if (string.IsNullOrWhiteSpace(rawUrl))
                continue;

            var normalizedUrl = rawUrl.ToLowerInvariant();

            if (normalizedUrl == "/")
            {
                if (path == "/" || string.IsNullOrWhiteSpace(path))
                    return "active";
            }
            else if (path == normalizedUrl || path.StartsWith(normalizedUrl + "/") || path.StartsWith(normalizedUrl + "?"))
            {
                return "active";
            }
        }

        return "";
    }

    string BuildInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "CS";

        var parts = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(x => x.Substring(0, 1).ToUpperInvariant());

        return string.Concat(parts);
    }

    var currentConference = DbContext.Conferences
        .OrderByDescending(x => x.IsActive)
        .ThenByDescending(x => x.StartDate)
        .FirstOrDefault();

    var publicProgramUrl = currentConference != null
        ? $"/Program?conferenceId={currentConference.Id}"
        : "/";

    var publicMenuItems = DbContext.MenuItems
        .Where(x => x.IsActive && x.MenuLocation == "Public")
        .OrderBy(x => x.SortOrder)
        .ToList();

    var themeMap = DbContext.SiteSettings
        .Where(x => x.Key.StartsWith("Theme."))
        .ToDictionary(x => x.Key, x => x.Value);

    string Theme(string key, string fallback) => themeMap.TryGetValue(key, out var v) && !string.IsNullOrWhiteSpace(v) ? v : fallback;

    var brandLogoUrl = Theme("Theme.BrandLogoUrl", currentConference?.LogoPath ?? "");
    var brandText = Theme("Theme.BrandText", currentConference?.Name ?? "Conference System");
    var loginButtonText = Theme("Theme.LoginButtonText", "Giriş Yap");
    var loginButtonUrl = Theme("Theme.LoginButtonUrl", "/AdminAuth/Login");
    var brandInitials = BuildInitials(currentConference?.ShortName ?? currentConference?.Name ?? brandText);
    var topInfo = currentConference != null
        ? $"{currentConference.StartDate:dd MMMM yyyy} - {currentConference.EndDate:dd MMMM yyyy} • {currentConference.Location}"
        : "Konferans yönetim sistemi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Conference System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-dynamic.css" asp-append-version="true" />

    <style>
        :root {
            --theme-primary: @Theme("Theme.Primary", "#7C5CFC");
            --theme-secondary: @Theme("Theme.Secondary", "#D8CCFF");
            --theme-accent: @Theme("Theme.Accent", "#22D3EE");
            --theme-bg: @Theme("Theme.Background", "#0B1020");
            --theme-surface: @Theme("Theme.Surface", "rgba(255,255,255,0.08)");
            --theme-border: @Theme("Theme.Border", "rgba(255,255,255,0.14)");
            --theme-heading: @Theme("Theme.Heading", "#F8FAFC");
            --theme-text: @Theme("Theme.Text", "#D9E2F2");
            --theme-muted: @Theme("Theme.Muted", "#9FB0CC");
            --theme-header-bg: @Theme("Theme.HeaderBg", "rgba(11,16,32,0.75)");
            --theme-header-text: @Theme("Theme.HeaderText", "#F8FAFC");
            --theme-footer-bg: @Theme("Theme.FooterBg", "rgba(11,16,32,0.8)");
            --theme-footer-text: @Theme("Theme.FooterText", "#CBD5E1");
            --theme-button-bg: @Theme("Theme.ButtonBg", "#7C5CFC");
            --theme-button-text: @Theme("Theme.ButtonText", "#FFFFFF");
            --theme-badge-bg: @Theme("Theme.BadgeBg", "rgba(34,211,238,0.14)");
            --theme-badge-text: @Theme("Theme.BadgeText", "#67E8F9");
        }
    </style>
</head>
<body class="glass-body">
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-grid"></div>

    <header style="display:none;" class="site-header-modern glass-header-shell">
        <div class="header-topline glass-line">
            <div class="container d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div class="header-topline-text">@topInfo</div>
                <div class="header-topline-actions">
                    @if (!string.IsNullOrWhiteSpace(portalRole))
                    {
                        <form asp-controller="Access" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="header-chip header-chip-outline">Panelden Çık</button>
                        </form>
                    }
                    <a class="header-chip" href="@loginButtonUrl">@loginButtonText</a>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-xl modern-navbar glass-nav-shell">
            <div class="container">
                <a class="navbar-brand brand-modern" href="/">
                    @if (!string.IsNullOrWhiteSpace(brandLogoUrl))
                    {
                        <span class="brand-logo-wrap">
                            <img src="@brandLogoUrl" alt="@brandText" class="brand-logo-img" />
                        </span>
                    }
                    else
                    {
                        <span class="brand-logo-fallback">@brandInitials</span>
                    }
                    <span class="brand-text-wrap">
                        <span class="brand-eyebrow">Conference Experience</span>
                        <span class="brand-title">@brandText</span>
                    </span>
                </a>

                <button class="navbar-toggler modern-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Menüyü aç">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto align-items-xl-center site-menu-modern mb-2 mb-xl-0">
                        <li class="nav-item"><a class="nav-link @ActiveClass("/")" href="/">Ana Sayfa</a></li>
                        @foreach (var item in publicMenuItems)
                        {
                            if (item.Url.Equals("/", StringComparison.OrdinalIgnoreCase))
                            {
                                continue;
                            }

                            <li class="nav-item">
                                <a class="nav-link @ActiveClass(item.Url)" href="@item.Url" target="@(item.OpenInNewTab ? "_blank" : "_self")">
                                    @item.Title
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @ActiveClass("/submission", "/submissiontracking", "/access/login", "/program")" href="#" id="katilimDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Katılım
                            </a>
                            <ul class="dropdown-menu modern-dropdown" aria-labelledby="katilimDropdown">
                                <li><a class="dropdown-item @ActiveClass("/submission/create")" href="/Submission/Create">Bildiri Gönder</a></li>
                                <li><a class="dropdown-item @ActiveClass("/submissiontracking")" href="/SubmissionTracking">Başvuru Takibi</a></li>
                                <li><a class="dropdown-item @ActiveClass("/access/login")" href="/Access/Login">Panel Girişi</a></li>
                                <li><a class="dropdown-item @ActiveClass("/program")" href="@publicProgramUrl">Program</a></li>
                            </ul>
                        </li>
                    </ul>

                    <div class="d-none d-xl-flex align-items-center gap-2 header-utility-right">
                        <a class="nav-cta" href="/Submission/Create">Özet Gönder</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="page-wrapper">
        <div class="container py-4 py-lg-5">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer-modern glass-footer-shell">
        <div class="container text-center">© @DateTime.Now.Year - @(currentConference?.Name ?? "Conference System")</div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
